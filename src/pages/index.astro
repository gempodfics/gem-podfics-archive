---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gem Podfics">
  <main class="home">
    <section class="hero">
      <div class="hero-text">
        <h1 class="hero-tagline">Gem <em>Podfics.</em></h1>
        <p class="hero-description">
          My personal audio archive fueled by hyperfixations. Enjoy mostly queer podfics, fandom-inspired ASMR, and audio gems that are spicy, sweet, and guaranteed to keep you up in more ways than one.
        </p>
      </div>
      <div class="hero-image">
        <!-- Replace src with your image when ready -->
        <img src="/hero-placeholder.jpg" alt="" class="hero-img" onerror="this.style.display='none'" />
        <div class="hero-img-placeholder"></div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .home {
    padding: 4rem 2rem 3rem;
    max-width: 900px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-image {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }

  .hero-img-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--bg-elevated) 0%, var(--bg-surface) 100%);
    border-radius: 12px;
    border: 1px solid var(--bg-elevated);
  }

  /* Hide placeholder when real image loads */
  .hero-img:not([src=""]) + .hero-img-placeholder {
    display: none;
  }

  .hero-tagline {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0;
  }

  .hero-tagline em {
    color: var(--accent-pink);
    font-style: italic;
  }

  .hero-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0;
  }
</style>
