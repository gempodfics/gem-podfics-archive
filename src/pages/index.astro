---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gem Podfics">
  <main class="home">
    <section class="hero">
      <div class="hero-text">
        <h1 class="hero-tagline">Gem <em>Podfics.</em></h1>
        <p class="hero-description">
          My personal audio archive fueled by hyperfixations. Enjoy mostly queer podfics, fandom-inspired ASMR, and audio gems that are spicy, sweet, and guaranteed to keep you up in more ways than one.
        </p>
      </div>
      <div class="hero-image">
        <!-- Swap /hero.jpg with your real image when ready -->
        <img src="/hero.jpg" alt="Gem Podfics hero image" class="hero-img" />
      </div>
    </section>
  </main>
</Layout>

<style>
  .home {
    padding-top: 8rem;
    padding-bottom: 8rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: 90rem;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .home {
      padding-left: 6rem;
      padding-right: 6rem;
    }
  }

  /* Hero: stacked on mobile, asymmetric 7/5 grid on desktop */
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 6rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .hero {
      grid-template-columns: 7fr 5fr;
      gap: 4rem;
    }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-tagline {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0;
  }

  .hero-tagline em {
    color: var(--accent-pink);
    font-style: italic;
  }

  .hero-description {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0;
    max-width: 42rem;
  }

  .hero-image {
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: 1.5rem;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    transition: mix-blend-mode 0.7s ease;
  }

  .hero-image:hover .hero-img {
    mix-blend-mode: normal;
  }
</style>
