<script>
  const row = document.getElementById('recs-row') as HTMLElement | null;
  const prevBtn = document.getElementById('recs-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('recs-next') as HTMLButtonElement | null;

  const SCROLL_AMOUNT = 160 * 3 + 16 * 2; // ~3 cards + gaps

  function updateArrows() {
    if (!row || !prevBtn || !nextBtn) return;
    prevBtn.disabled = row.scrollLeft <= 0;
    nextBtn.disabled = row.scrollLeft + row.clientWidth >= row.scrollWidth - 1;
  }

  prevBtn?.addEventListener('click', () => {
    row?.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' });
  });

  nextBtn?.addEventListener('click', () => {
    row?.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' });
  });

  row?.addEventListener('scroll', updateArrows, { passive: true });

  // Set initial state once DOM is ready
  updateArrows();

  //  Commissioned Story Art arrows
  const artRow = document.getElementById('art-row') as HTMLElement | null;
  const artPrev = document.getElementById('art-prev') as HTMLButtonElement | null;
  const artNext = document.getElementById('art-next') as HTMLButtonElement | null;

  function updateArtArrows() {
    if (!artRow || !artPrev || !artNext) return;
    artPrev.disabled = artRow.scrollLeft <= 0;
    artNext.disabled = artRow.scrollLeft + artRow.clientWidth >= artRow.scrollWidth - 1;
  }

  artPrev?.addEventListener('click', () => {
    artRow?.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' });
  });

  artNext?.addEventListener('click', () => {
    artRow?.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' });
  });

  artRow?.addEventListener('scroll', updateArtArrows, { passive: true });
  updateArtArrows();
</script>
