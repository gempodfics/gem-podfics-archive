---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gem Podfics">
  <main class="home">
    <section class="hero">
      <div class="hero-text">
        <h1 class="hero-tagline">Gem <em>Podfics.</em></h1>
        <p class="hero-description">
          My personal audio archive fueled by hyperfixations. Enjoy mostly queer podfics, fandom-inspired ASMR, and audio gems that are spicy, sweet, and guaranteed to keep you up in more ways than one.
        </p>
      </div>
      <div class="hero-image">
        <!-- Swap /hero.jpg with your real image when ready -->
        <img src="/hero.jpg" alt="Gem Podfics hero image" class="hero-img" />
        <div class="hero-img-placeholder" aria-hidden="true">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
          <span>Hero image</span>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .home {
    padding: 4rem 2rem 3rem;
    max-width: 1000px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 4rem;
    align-items: center;
  }

  @media (min-width: 600px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-tagline {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0;
  }

  .hero-tagline em {
    color: var(--accent-pink);
    font-style: italic;
  }

  .hero-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Image container */
  .hero-image {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }

  .hero-img-placeholder {
    display: none;
  }
</style>
