---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gem Podfics">
  <main class="coming-soon">
    <h1>Gem Podfics</h1>
    <p>Coming Soon</p>
  </main>
</Layout>

<style>
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 0.75rem;
    text-align: center;
  }

  h1 {
    color: var(--accent-pink);
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0;
  }

  p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin: 0;
    letter-spacing: 0.05em;
  }
</style>
