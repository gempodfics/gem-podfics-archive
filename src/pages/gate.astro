---
// Standalone page — intentionally does NOT use Layout.astro to avoid redirect loop
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Gem Podfics</title>
    <link rel="icon" type="image/png" href="/gempodfics-favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg-primary:        #0E0A14;
        --bg-surface:        #1A1028;
        --bg-elevated:       #251640;
        --accent-pink:       #E8588A;
        --accent-pink-hover: #F07AA8;
        --text-primary:      #EDE4FA;
        --text-secondary:    #C4AEDD;
        --text-muted:        #A88BC5;
      }

      html, body {
        height: 100%;
        font-family: 'Crimson Pro', Georgia, serif;
        background: var(--bg-primary);
        color: var(--text-primary);
      }

      /* ── Subtle background glow ── */
      .gate-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .bg-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(232,88,138,0.06) 0%, transparent 65%);
      }

      /* ── Gate layout ── */
      .gate-wrap {
        position: relative;
        z-index: 10;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
        text-align: center;
      }

      .gate-card {
        width: 100%;
        max-width: 480px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.75rem;
      }

      /* ══════════════════════════════════════
         SLEEVE + RECORD ARTWORK
      ══════════════════════════════════════ */
      .artwork-wrap {
        position: relative;
        width: 230px;
        height: 190px;
        flex-shrink: 0;
      }

      /* Vinyl record — behind sleeve, peeks right */
      .vinyl-record {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 170px;
        height: 170px;
        border-radius: 50%;
        background:
          repeating-radial-gradient(
            circle at center,
            #120508 0px, #120508 5px,
            #1a0810 5px, #1a0810 6px
          );
        box-shadow:
          inset 0 0 30px rgba(0,0,0,0.6),
          0 0 0 1px rgba(255,255,255,0.04),
          0 4px 24px rgba(0,0,0,0.6);
        animation: spin 4s linear infinite;
        z-index: 1;
      }

      /* Iridescent sheen — makes spin visible */
      .vinyl-sheen {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        pointer-events: none;
        background:
          radial-gradient(ellipse 58% 38% at 30% 26%, rgba(255,255,255,0.11) 0%, rgba(255,255,255,0.05) 45%, transparent 72%),
          radial-gradient(ellipse 28% 44% at 80% 72%, rgba(255,255,255,0.06) 0%, transparent 62%),
          conic-gradient(from 205deg at 50% 50%,
            transparent 0deg, rgba(190,160,255,0.07) 35deg, rgba(155,205,255,0.06) 75deg,
            transparent 110deg, transparent 200deg, rgba(255,185,220,0.06) 258deg, transparent 300deg);
        mix-blend-mode: screen;
      }

      /* Center label */
      .vinyl-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 36%;
        height: 36%;
        border-radius: 50%;
        background: radial-gradient(circle, var(--accent-pink) 0%, #c0406a 60%, #8b1f3f 100%);
        border: 2px solid rgba(255,255,255,0.1);
      }
      .vinyl-label::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--bg-primary);
      }

      @keyframes spin {
        from { transform: translateY(-50%) rotate(0deg); }
        to   { transform: translateY(-50%) rotate(360deg); }
      }

      /* Sleeve — sits in front */
      .sleeve {
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 170px;
        height: 170px;
        border-radius: 10px;
        overflow: hidden;
        z-index: 2;
        background: var(--bg-elevated);
        box-shadow:
          4px 0 16px rgba(0,0,0,0.5),
          0 4px 20px rgba(0,0,0,0.4);
      }
      .sleeve img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
      }
      .sleeve::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, transparent 60%);
        pointer-events: none;
      }

      /* ── Wordmark ── */
      .wordmark-name {
        font-size: 1.3rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      /* ── Divider ── */
      .divider {
        width: 48px;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--accent-pink), transparent);
      }

      /* ── Headline ── */
      .gate-headline {
        font-size: clamp(1.6rem, 5vw, 2.2rem);
        font-weight: 700;
        line-height: 1.25;
        color: var(--text-primary);
      }
      .gate-headline em {
        font-style: italic;
        color: var(--accent-pink);
      }

      /* ── Body copy ── */
      .gate-body {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--text-secondary);
        max-width: 400px;
      }
      .gate-body strong {
        color: var(--text-primary);
        font-weight: 600;
      }

      /* ── Buttons ── */
      .gate-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.875rem;
        width: 100%;
        max-width: 320px;
      }

      .btn-primary {
        width: 100%;
        padding: 0.9rem 2rem;
        border-radius: 999px;
        background: var(--accent-pink);
        color: #fff;
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 1.1rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        letter-spacing: 0.02em;
        transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
        box-shadow: 0 4px 20px rgba(232,88,138,0.35);
      }
      .btn-primary:hover {
        background: var(--accent-pink-hover);
        transform: translateY(-1px);
        box-shadow: 0 6px 28px rgba(232,88,138,0.45);
      }
      .btn-primary:active { transform: translateY(0); }

      .btn-ghost {
        width: 100%;
        padding: 0.9rem 2rem;
        border-radius: 999px;
        background: none;
        border: 1.5px solid var(--text-muted);
        color: var(--text-muted);
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.02em;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
      }
      .btn-ghost:hover {
        border-color: var(--text-secondary);
        color: var(--text-secondary);
        background: rgba(168,139,197,0.08);
      }

      /* ── Fine print ── */
      .gate-fine {
        font-size: 0.85rem;
        color: var(--text-muted);
        opacity: 0.7;
      }

      /* ── Exit animation ── */
      .gate-wrap.entered .gate-card {
        animation: fadeOut 0.4s ease forwards;
      }
      @keyframes fadeOut {
        to { opacity: 0; transform: translateY(-8px); }
      }

      /* Mobile */
      @media (max-width: 480px) {
        .gate-card { gap: 1.4rem; }
        .artwork-wrap { width: 200px; height: 165px; }
        .sleeve, .vinyl-record { width: 148px; height: 148px; }
      }
    </style>
  </head>
  <body>

    <div class="gate-bg">
      <div class="bg-glow"></div>
    </div>

    <div class="gate-wrap" id="gate-wrap">
      <div class="gate-card">

        <div class="artwork-wrap">
          <div class="vinyl-record">
            <div class="vinyl-sheen"></div>
            <div class="vinyl-label"></div>
          </div>
          <div class="sleeve">
            <img src="/Headshot.PNG" alt="Gem Asteria" />
          </div>
        </div>

        <span class="wordmark-name">Gem Podfics</span>

        <div class="divider"></div>

        <h1 class="gate-headline">
          You're about to enter<br><em>Gem's World.</em>
        </h1>

        <p class="gate-body">
          Fair warning: this archive is home to <strong>explicit audio and artwork</strong>
          (smut with plot) with a sprinkle of sweet.<br><br>
          Grab your headphones if you're ready.
        </p>

        <div class="gate-actions">
          <button class="btn-primary" id="btn-enter">Let me in</button>
          <button class="btn-ghost" id="btn-leave">Not today</button>
        </div>

        <p class="gate-fine">This preference is saved for your current tab only.</p>

      </div>
    </div>

    <script>
      document.getElementById('btn-enter')!.addEventListener('click', () => {
        sessionStorage.setItem('gem_gate_passed', '1');
        const wrap = document.getElementById('gate-wrap')!;
        wrap.classList.add('entered');
        setTimeout(() => {
          window.location.replace('/');
        }, 400);
      });

      document.getElementById('btn-leave')!.addEventListener('click', () => {
        if (window.history.length > 1) {
          history.back();
        } else {
          window.location.href = 'https://www.google.com';
        }
      });
    </script>

  </body>
</html>
