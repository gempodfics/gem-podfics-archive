---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Podfic Commissions" variant="home">
  <main class="commissions">
    <section class="commissions-intro">
      <h1 class="page-title">Gem's Podfic Commissions</h1>
      <p class="intro-text">
        Email me or DM me on Bluesky
        <a
          href="https://bsky.app/profile/gempodfics.bsky.social"
          target="_blank"
          rel="noopener"
          class="accent-link"
        >
          (@gempodfics.bsky.social)
        </a>
        . Links can also be found on my homepage.
      </p>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Price Overview: Rates By Word Count</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <p class="prose">
        Price is based on word count bands of the fic - not by chapters.
      </p>
      <p class="prose">
        Finish time is calculated based on average reading speed and overall tempo of the story being voiced, the trailer/intro, and background music/transition music if added.
      </p>
      <p class="prose">
        If you are interested in a project that is larger than 16K words, let me know and we can discuss what's possible and payment plans.
      </p>

      <div class="table-scroll" aria-label="Rates by word count table (scroll on mobile)">
        <table class="rates-table">
          <thead>
            <tr>
              <th>Word Count (Approx)</th>
              <th>Approx Finish Time</th>
              <th>Cost (Record + Edit)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>0 - 2.5K</td>
              <td>Up to 15 mins</td>
              <td>$30.00 USD</td>
            </tr>
            <tr>
              <td>2.5K - 5.5K</td>
              <td>15 - 30 mins</td>
              <td>$60.00 USD</td>
            </tr>
            <tr>
              <td>5.5K - 7.5K</td>
              <td>30 - 45 mins</td>
              <td>$100.00 USD</td>
            </tr>
            <tr>
              <td>7.5K - 10.5K</td>
              <td>45 - 60 mins</td>
              <td>$130.00 USD</td>
            </tr>
            <tr>
              <td>10.5K - 12.5K</td>
              <td>60 - 75 mins</td>
              <td>$150.00 USD</td>
            </tr>
            <tr>
              <td>12.5K - 15.5K</td>
              <td>75 - 90 mins</td>
              <td>$175.00 USD</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">How It Works</h2>
          <div class="section-rule"></div>
        </div>
      </div>
      <ol class="numbered how-it-works">
        <li>
          Provide a link to your fic
          <span class="small">With details including word count</span>
        </li>
        <li>
          I'll review and confirm your request
          <span class="small">I'll review your request and reach back out to confirm preferences and timeline.</span>
        </li>
        <li>
          Payment processing and recording begins
          <span class="small">Once we agree on the details, you'll receive.</span>
        </li>
        <li>
          Sign off and delivery
          <span class="small">
            I'll have you review the audio for any *minor edits where I'll clean up and package for delivery.
            <br />
            Minor edits are determined at my discretion. Anything major that deviates from the original scope will incur an additional charge. I will make revisions free-of-charge for any errors I make.
          </span>
        </li>
      </ol>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">What You'll Get</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <ol class="numbered">
        <li>MP3 file(s). The most capable format.</li>
        <li>Audio editing. Mastered audio (Noise reduction).</li>
        <li>
          Music/FX placement
          <span class="small">If desired.</span>
        </li>
        <li>
          Separate teaser audio file
          <span class="small">Use as a stand alone promo or layer on top of your own graphic for promo posts on BlueSky, Tumblr, etc.</span>
        </li>
      </ol>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Delivery Details</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <div class="subhead">Time Frame</div>
      <p class="prose">
        6-8 weeks (earlier or later depending on personal schedule).
      </p>
      <p class="prose">
        *I will confirm deadlines on a per project basis before any work begins.
      </p>

      <div class="subhead">Via Google Drive</div>
      <p class="prose">
        Files uploaded and sent via a locked Google Drive link.
      </p>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Payment and Refunds</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <div class="prose">
        <strong>Payment Methods:</strong> PayPal, Venmo, Buy Me Coffee
      </div>
      <p class="prose">
        I accept payments through PayPal, Venmo, or BuyMeACoffee.
      </p>

      <p class="prose">
        For projects $65 and below: payment is required upfront before I proceed.
      </p>
      <p class="prose">
        For projects $65 and above: 50% of the total is required upfront, and the remaining payment before final delivery.
      </p>

      <div class="subhead">Refund Policy</div>
      <ul class="bullets">
        <li>
          If the commission is cancelled (by me or the client) before work has started, then the client will receive a full refund.
        </li>
        <li>
          If I cancel the commission due to my inability to complete it at any state, a full refund will be given.
        </li>
        <li>
          If the client cancels the commission during progress, the amount refunded will be on a case-by-case basis and up to my discretion.
        </li>
        <li>No refunds will be given for completed or nearly completed commissions.</li>
        <li>
          I reserve the right to cancel a commission at any time, for any reason, and without explanation.
        </li>
      </ul>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">Fandoms I Record For</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <p class="prose">
        I am open to others but these are my mains.
      </p>
      <ul class="bullets">
        <li>Heaven Official's Blessing (TGCF)</li>
        <li>The Grand Master of Demonic Cultivation (MDZS)</li>
        <li>The Scum Villian's Self-Saving System (SVSSS)</li>
        <li>The Husky and His White Cat Shizun (2HA/Erha)</li>
      </ul>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">My Dynamics</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <ul class="bullets">
        <li>Mostly all, including dead dove.</li>
        <li>
          *Will let you know if either I am not comfortable voicing either due to the content or I don't think I can do your story justice with my voice range.
        </li>
      </ul>
    </section>

    <section class="copy-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">FAQs</h2>
          <div class="section-rule"></div>
        </div>
      </div>

      <dl class="faq">
        <div class="faq-item">
          <dt>What's the difference between your podfic commissions and those on Ao3?</dt>
          <dd>
            Podfic commissions are created for customers who compensate me. The client owns the content and can use it as they wish.
            <br />
            The podfics on my Ao3 are ones where I approach writers to record their stories for free, and sometimes commission artists for fic art out of my own pocket.
            This is what I consider my content.
          </dd>
        </div>

        <div class="faq-item">
          <dt>How do you select stories to record for your Ao3?</dt>
          <dd>
            It's a combination of my personal favorite stories and ones I feel I can comfortably/naturally voice!
          </dd>
        </div>

        <div class="faq-item">
          <dt>Why mp3 only for podfic commissions?</dt>
          <dd>
            Your podfics sometimes include art. Editing audio takes significantly longer than recording audio. My rates reflect the post-editing involved for producing high-quality audio in my style.
            Building in costs for additional things such as a video trailer and commissioned art would significantly raise the base price, and lengthen the turnaround time, and I want to offer equitable price points.
          </dd>
        </div>

        <div class="faq-item">
          <dt>What is your recording set-up like?</dt>
          <dd>
            I use an XLR mic, Scarlett Solo interface, and do my audio mixing in GarageBand.
          </dd>
        </div>
      </dl>

      <div class="subhead">FYIs</div>
      <p class="prose">
        Please note commissions are not first come, first serve. This is to ensure that I produce the best quality commission for you and so you get the most out of your money!
      </p>

      <div class="subhead">Accepting a commission</div>
      <p class="prose">
        If I accept it, you will be notified through your preferred method of contact to discuss next steps including timelines, arrangement for payment, and any additional questions or details needed to get started.
      </p>

      <div class="subhead">Rejecting a commission</div>
      <p class="prose">
        If I reject it, it means I will not complete your commission request. There might be several reasons for this including, but not limited to, being too unfamiliar enough with the material to be able to execute the request at the quality it deserves, uncomfortable with the content, overall availability, etc.
      </p>
      <p class="prose">
        If a week has gone by and you have not heard from me, you can assume I have not accepted your commission. I reserve the right to reject any commission request without the need to provide a reason.
      </p>
    </section>

    <section class="back-bottom">
      <a href="/" class="back-link">Back To Home</a>
    </section>
  </main>
</Layout>

<style>
  .commissions {
    padding-top: 8rem;
    padding-bottom: 6rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: 90rem;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .commissions {
      padding-left: 6rem;
      padding-right: 6rem;
    }
  }

  .commissions-intro {
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 2.1rem;
    font-weight: 800;
    margin: 0 0 1rem 0;
    color: var(--text-primary);
  }

  .intro-text {
    margin: 0 0 1.25rem 0;
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 1rem;
    max-width: 52rem;
  }

  .accent-link {
    color: var(--accent-pink);
    text-decoration: none;
    font-weight: 700;
    border-bottom: 1px solid rgba(232, 88, 138, 0.35);
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent-pink);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .copy-section {
    margin-bottom: 4.5rem;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.6rem 0;
  }

  .section-rule {
    width: 3rem;
    height: 3px;
    background-color: var(--accent-pink);
    border-radius: 2px;
  }

  .prose {
    margin: 0.75rem 0;
    color: var(--text-secondary);
    line-height: 1.85;
    font-size: 1rem;
  }

  .hint {
    margin-top: 0.25rem;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .footnote {
    margin: 0.6rem 0;
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.98rem;
  }

  .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.25rem;
  }

  .rates-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    color: var(--text-secondary);
    font-size: 0.98rem;
  }

  .rates-table th,
  .rates-table td {
    padding: 0.75rem 0.85rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    vertical-align: top;
    text-align: left;
    white-space: nowrap;
  }

  .rates-table thead th {
    color: var(--text-primary);
    border-bottom: 1px solid rgba(232, 88, 138, 0.35);
  }

  .numbered {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  /* Make the main step titles read as "section-like" labels (white),
     while keeping the supporting text (`.small`) muted. */
  .how-it-works {
    color: var(--text-primary);
  }

  .numbered li {
    margin: 0.65rem 0;
  }

  .small {
    display: block;
    color: var(--text-muted);
    font-size: 0.98rem;
    margin-top: 0.25rem;
  }

  .subhead {
    margin-top: 1.75rem;
    font-weight: 800;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .bullets {
    margin: 0.5rem 0;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  .bullets li {
    margin: 0.5rem 0;
  }

  .faq {
    margin: 0;
  }

  .faq-item {
    margin: 0.85rem 0 1.3rem 0;
  }

  .faq-item dt {
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
    line-height: 1.4;
  }

  .faq-item dd {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  .back-bottom {
    margin-top: 1.5rem;
  }
</style>

