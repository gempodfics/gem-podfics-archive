---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Podfic Commissions" variant="home">
  <main class="commissions">

    <!-- 1. HERO -->
    <section class="hero">
      <h1>Gem's Podfic Commissions</h1>
      <p class="subtext">If you're interested in a commission, reach out! I'd love to hear what you have in mind.</p>
      <div class="btn-group">
        <a class="btn btn-primary" href="mailto:gemasteria22@gmail.com">Email Me</a>
        <a class="btn btn-secondary" href="https://bsky.app/profile/gempodfics.bsky.social" target="_blank" rel="noopener">DM on Bluesky</a>
      </div>
    </section>

    <!-- 2. PRICING TABLE -->
    <section>
      <h2 class="section-heading">Rates by Word Count</h2>
      <div class="pricing-notes">
        <p>Price is based on word count bands — not chapters.</p>
        <p>Finish time includes recording, trailer/intro, and music if added.</p>
      </div>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Word Count</th>
              <th>Approx Finish Time</th>
              <th>Cost</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>0–2.5K</td>
              <td>Up to 15 mins</td>
              <td class="col-cost">$30</td>
            </tr>
            <tr>
              <td>2.5K–5.5K</td>
              <td>15–30 mins</td>
              <td class="col-cost">$60</td>
            </tr>
            <tr>
              <td>5.5K–7.5K</td>
              <td>30–45 mins</td>
              <td class="col-cost">$100</td>
            </tr>
            <tr>
              <td>7.5K–10.5K</td>
              <td>45–60 mins</td>
              <td class="col-cost">$130</td>
            </tr>
            <tr>
              <td>10.5K–12.5K</td>
              <td>60–75 mins</td>
              <td class="col-cost">$150</td>
            </tr>
            <tr>
              <td>12.5K–15.5K</td>
              <td>75–90 mins</td>
              <td class="col-cost">$175</td>
            </tr>
            <tr class="row-quote">
              <td>16K+</td>
              <td colspan="2"><em>Contact for quote</em></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="pricing-footnote">💎 Interested in a 16K+ project? Get in touch to discuss options and payment plans.</p>
    </section>

    <!-- 3. HOW IT WORKS -->
    <section>
      <h2 class="section-heading">How It Works</h2>
      <div class="steps-list">

        <div class="card step-card">
          <div class="step-number">1</div>
          <div class="step-body">
            <h3>Share your fic</h3>
            <p>Send me a link with word count details.</p>
          </div>
        </div>

        <div class="card step-card">
          <div class="step-number">2</div>
          <div class="step-body">
            <h3>I'll review your request</h3>
            <p>I'll reach back out to confirm preferences and timeline.</p>
          </div>
        </div>

        <div class="card step-card">
          <div class="step-number">3</div>
          <div class="step-body">
            <h3>Payment &amp; recording begins</h3>
            <p>Once we agree on details, you'll receive a payment link. Recording starts after payment is confirmed.</p>
          </div>
        </div>

        <div class="card step-card">
          <div class="step-number">4</div>
          <div class="step-body">
            <h3>Sign off &amp; delivery</h3>
            <p>You'll review the audio for minor edits. I'll clean up and package for delivery. Revisions for my errors are always free.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- 4. WHAT YOU'LL GET -->
    <section>
      <h2 class="section-heading">What You'll Get</h2>
      <div class="deliverables-grid">

        <div class="card deliverable-card">
          <h3>MP3 File(s)</h3>
          <p>The most versatile, universally compatible format.</p>
        </div>

        <div class="card deliverable-card">
          <h3>Mastered Audio</h3>
          <p>Full editing with noise reduction for clean, professional sound.</p>
        </div>

        <div class="card deliverable-card">
          <h3>Music &amp; FX</h3>
          <p>Background music and sound effects placed throughout, if desired.</p>
        </div>

        <div class="card deliverable-card">
          <h3>Teaser Audio File</h3>
          <p>A standalone promo clip you can share on Bluesky, Tumblr, and more.</p>
        </div>

      </div>
    </section>

    <!-- 5. DELIVERY DETAILS -->
    <section>
      <h2 class="section-heading">Delivery Details</h2>
      <div class="delivery-grid">

        <div class="card delivery-card">
          <div class="label">Time Frame</div>
          <p>6–8 weeks, earlier or later depending on my schedule. Deadlines confirmed per project before work begins.</p>
        </div>

        <div class="card delivery-card">
          <div class="label">Via Google Drive</div>
          <p>Files uploaded and sent via a private, locked Google Drive link.</p>
        </div>

      </div>
    </section>

    <!-- 6. PAYMENT & REFUNDS -->
    <section>
      <h2 class="section-heading">Payment &amp; Refunds</h2>

      <div class="payment-chips">
        <span class="chip">PayPal</span>
        <span class="chip">Venmo</span>
      </div>

      <div class="payment-tiers">
        <div class="tier-box">
          <div class="tier-label">$65 and under</div>
          <p>Full payment required upfront before work begins.</p>
        </div>
        <div class="tier-box">
          <div class="tier-label">$65 and over</div>
          <p>50% upfront, remaining balance due before final delivery.</p>
        </div>
      </div>

      <p class="refund-heading">Refund Policy</p>
      <ul class="refund-list">
        <li>Cancelled before work starts → full refund.</li>
        <li>Cancelled by me at any stage → full refund.</li>
        <li>Cancelled by client during progress → case-by-case, at my discretion.</li>
        <li>No refunds for completed or nearly completed commissions.</li>
        <li>I reserve the right to cancel any commission at any time without explanation.</li>
      </ul>
    </section>

    <!-- 7. FANDOMS & DYNAMICS -->
    <section>
      <h2 class="section-heading">Fandoms &amp; Dynamics</h2>
      <div class="fandoms-grid">

        <div class="card fandoms-col">
          <h3>Fandoms I Record For</h3>
          <p class="fandoms-intro">These are my mains but I'm open to others, just ask!</p>
          <div class="fandom-tags">
            <span class="fandom-tag">TGCF</span>
            <span class="fandom-tag">MDZS</span>
            <span class="fandom-tag">SVSSS</span>
            <span class="fandom-tag">2HA/Erha</span>
            <span class="fandom-tag">Wind Breaker</span>
            <span class="fandom-tag">LADs</span>
          </div>
        </div>

        <div class="card dynamics-col">
          <h3>My Dynamics</h3>
          <p class="dynamics-body">Mostly all, including dead dove. I'll let you know if I'm not comfortable with the content or don't feel I can do your story justice.</p>
        </div>

      </div>
    </section>

    <!-- 8. FAQs -->
    <section>
      <h2 class="section-heading">FAQs</h2>
      <div class="faqs-list">

        <details>
          <summary>What's the difference between your commissions and your Ao3 podfics?</summary>
          <div class="faq-answer">
            Commissions are created for clients who pay me — the client owns the content. My Ao3 podfics are ones I choose to record for free, sometimes commissioning art out of my own pocket.
          </div>
        </details>

        <details>
          <summary>How do you select stories for your Ao3?</summary>
          <div class="faq-answer">
            A mix of personal favorites and stories I feel I can comfortably and naturally voice.
          </div>
        </details>

        <details>
          <summary>Why MP3 only?</summary>
          <div class="faq-answer">
            Editing audio takes significantly longer than recording. My rates reflect the post-production involved. Adding commissioned art would significantly raise the price and turnaround time — MP3 keeps things equitable.
          </div>
        </details>

        <details>
          <summary>What's your recording set-up?</summary>
          <div class="faq-answer">
            XLR mic, Scarlett Solo interface, audio mixing in GarageBand.
          </div>
        </details>

      </div>

      <div class="faq-note">
        💎 Commissions are not first come, first serve. This ensures I give every project the time and quality it deserves.
      </div>
    </section>

    <!-- 9. BOTTOM CTA -->
    <section class="bottom-cta">
      <h2>Ready to Work Together?</h2>
      <p class="subtext">Reach out via email or Bluesky and let's talk about your fic.</p>
      <div class="btn-group">
        <a class="btn btn-primary" href="mailto:gemasteria22@gmail.com">Email Me</a>
        <a class="btn btn-secondary" href="https://bsky.app/profile/gempodfics.bsky.social" target="_blank" rel="noopener">DM on Bluesky</a>
      </div>
    </section>

  </main>
</Layout>

<style>
  .commissions {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
    padding-bottom: 6rem;
  }

  @media (min-width: 640px) {
    .commissions { padding-left: 3rem; padding-right: 3rem; }
  }

  section {
    margin-bottom: 4rem;
  }

  /* ── SECTION HEADINGS ── */
  .section-heading {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .section-heading::after {
    content: '';
    display: block;
    width: 3rem;
    height: 3px;
    background: var(--accent-pink);
    margin-top: 0.45rem;
    border-radius: 2px;
  }

  /* ── CARDS ── */
  .card {
    background: var(--bg-surface);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 1.25rem;
  }

  /* ── BUTTONS ── */
  .btn-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent-pink);
    color: #0E0A14;
    border: 2px solid var(--accent-pink);
  }
  .btn-primary:hover {
    background: var(--accent-pink-hover);
    border-color: var(--accent-pink-hover);
    color: #0E0A14;
    box-shadow: 0 0 16px rgba(232, 88, 138, 0.35);
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent-pink);
    border: 2px solid var(--accent-pink);
  }
  .btn-secondary:hover {
    background: rgba(232, 88, 138, 0.1);
    color: var(--accent-pink-hover);
    border-color: var(--accent-pink-hover);
  }

  /* ── HERO ── */
  .hero {
    padding-top: 6rem;
    padding-bottom: 1rem;
    text-align: center;
  }

  .hero h1 {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: clamp(1.9rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .hero .subtext {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .hero .btn-group {
    justify-content: center;
  }

  /* ── PRICING TABLE ── */
  .pricing-notes {
    margin-bottom: 0.85rem;
  }
  .pricing-notes p {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .table-scroll {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    min-width: 420px;
  }

  thead th {
    background: var(--bg-elevated);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.85rem 1.1rem;
    text-align: left;
    border-bottom: 2px solid var(--accent-pink);
  }

  tbody tr {
    transition: background 0.15s ease;
  }
  tbody tr:nth-child(odd)  { background: var(--bg-surface); }
  tbody tr:nth-child(even) { background: rgba(37, 22, 64, 0.45); }
  tbody tr:hover { background: var(--bg-elevated); }

  tbody td {
    padding: 0.8rem 1.1rem;
    color: var(--text-secondary);
    vertical-align: middle;
  }

  .col-cost {
    color: var(--accent-pink) !important;
    font-weight: 700;
  }

  .row-quote td {
    color: var(--text-muted);
    font-style: italic;
  }

  .pricing-footnote {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  /* ── HOW IT WORKS ── */
  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step-card {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
  }

  .step-number {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-pink);
    color: #0E0A14;
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }

  .step-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .step-body p {
    font-size: 0.92rem;
    color: var(--text-secondary);
  }

  /* ── WHAT YOU'LL GET ── */
  .deliverables-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 600px) {
    .deliverables-grid { grid-template-columns: 1fr 1fr; }
  }

  .deliverable-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .deliverable-card h3 {
    font-size: 0.97rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .deliverable-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* ── DELIVERY DETAILS ── */
  .delivery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 500px) {
    .delivery-grid { grid-template-columns: 1fr 1fr; }
  }

  .delivery-card .label {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 0.97rem;
    margin-bottom: 0.4rem;
  }

  .delivery-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* ── PAYMENT & REFUNDS ── */
  .payment-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .chip {
    display: inline-block;
    background: var(--bg-elevated);
    border: 1px solid rgba(232, 88, 138, 0.3);
    border-radius: 999px;
    padding: 0.3rem 0.9rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .payment-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 500px) {
    .payment-tiers { grid-template-columns: 1fr 1fr; }
  }

  .tier-box {
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 3px solid var(--accent-pink);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
  }

  .tier-box .tier-label {
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
    font-size: 0.97rem;
  }

  .tier-box p {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .refund-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .refund-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-left: 0.5rem;
  }

  .refund-list li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .refund-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    background: var(--accent-pink);
    border-radius: 50%;
  }

  /* ── FANDOMS & DYNAMICS ── */
  .fandoms-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 560px) {
    .fandoms-grid { grid-template-columns: 1fr 1fr; }
  }

  .fandoms-col h3,
  .dynamics-col h3 {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .fandoms-intro,
  .dynamics-body {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 0.85rem;
  }

  .fandom-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .fandom-tag {
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 6px;
    padding: 0.25rem 0.65rem;
    font-size: 0.83rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  /* ── FAQs ── */
  .faqs-list {
    display: flex;
    flex-direction: column;
  }

  details {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--bg-elevated);
  }

  details:first-of-type {
    border-radius: 12px 12px 0 0;
  }

  details:last-of-type {
    border-radius: 0 0 12px 12px;
    border-bottom: none;
  }

  summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    user-select: none;
    font-size: 0.95rem;
  }

  summary::-webkit-details-marker { display: none; }

  summary::after {
    content: '';
    display: block;
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--accent-pink);
    border-bottom: 2px solid var(--accent-pink);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    margin-top: -4px;
  }

  details[open] > summary::after {
    transform: rotate(-135deg);
    margin-top: 4px;
  }

  details[open] > summary {
    color: var(--accent-pink);
  }

  .faq-answer {
    padding: 0 1.25rem 1.1rem 1.25rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .faq-note {
    margin-top: 1.1rem;
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 0.9rem 1.1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  /* ── BOTTOM CTA ── */
  .bottom-cta {
    background: var(--bg-surface);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
  }

  .bottom-cta h2 {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .bottom-cta .subtext {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .bottom-cta .btn-group {
    justify-content: center;
  }
</style>
