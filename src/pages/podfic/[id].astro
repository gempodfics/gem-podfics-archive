</style>

<script define:vars={{ CIRCUMFERENCE, hasAudio }}>
  // ── Element refs ──
  const playerPage   = document.getElementById('player-page');
  const disc         = document.getElementById('vinyl-disc');
  const tonearm      = document.getElementById('tonearm-group');
  const tonearmSvg   = document.getElementById('tonearm-svg');
  const playBtn      = document.getElementById('play-btn');
  const iconPlay     = document.getElementById('icon-play');
  const iconPause    = document.getElementById('icon-pause');
  const skipBack     = document.getElementById('skip-back');
  const skipFwd      = document.getElementById('skip-fwd');
  const scrubTrack   = document.getElementById('scrubber-track');
  const scrubFill    = document.getElementById('scrubber-fill');
  const scrubThumb   = document.getElementById('scrubber-thumb');
  const timeElapsed  = document.getElementById('time-elapsed');
  const timeTotal    = document.getElementById('time-total');
  const audio        = document.getElementById('audio-player');

  // ── Mobile state refs ──
  const contentPlayBtn  = document.getElementById('content-play-btn');
  const sheetDismissBtn = document.getElementById('sheet-dismiss-btn');
  const miniPlayerBar   = document.getElementById('mini-player-bar');
  const miniPlayBtn     = document.getElementById('mini-play-btn');
  const miniIconPlay    = document.getElementById('mini-icon-play');
  const miniIconPause   = document.getElementById('mini-icon-pause');

  // ── Mobile sheet state ──
  let hasStarted = false; // true once audio has been played at least once

  function openSheet() {
    playerPage?.setAttribute('data-player-state', 'open');
  }

  function closeSheet() {
    playerPage?.setAttribute('data-player-state', 'content');
    if (hasStarted) {
      miniPlayerBar?.classList.add('visible');
      miniPlayerBar?.removeAttribute('aria-hidden');
    }
  }

  sheetDismissBtn?.addEventListener('click', closeSheet);

  if (!hasAudio || !audio) {
    if (playBtn) playBtn.disabled = true;
    if (contentPlayBtn) contentPlayBtn.disabled = true;
  } else {
    let isPlaying = false;
    let armLanded = false;

    // ── Time formatter ──
    function fmtTime(s) {
      if (!isFinite(s)) return '--:--';
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = Math.floor(s % 60);
      if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
      return `${m}:${String(sec).padStart(2,'0')}`;
    }

    // ── Arm land ──
    function landArm(callback) {
      tonearm.classList.remove('raised');
      tonearm.classList.add('on-groove');
      setTimeout(() => { if (callback) callback(); }, 900);
    }

    // ── Sync play/pause UI across all buttons ──
    function setPlaying(playing) {
      isPlaying = playing;
      if (playing) {
        disc.style.animationPlayState = 'running';
        disc.classList.add('glowing');
        tonearmSvg.classList.add('glowing');
        iconPlay.style.display = 'none';
        iconPause.style.display = '';
        playBtn.setAttribute('aria-label', 'Pause');
        if (miniIconPlay)  miniIconPlay.style.display  = 'none';
        if (miniIconPause) miniIconPause.style.display = '';
        miniPlayBtn?.setAttribute('aria-label', 'Pause');
      } else {
        disc.style.animationPlayState = 'paused';
        disc.classList.remove('glowing');
        tonearmSvg.classList.remove('glowing');
        iconPlay.style.display = '';
        iconPause.style.display = 'none';
        playBtn.setAttribute('aria-label', 'Play');
        if (miniIconPlay)  miniIconPlay.style.display  = '';
        if (miniIconPause) miniIconPause.style.display = 'none';
        miniPlayBtn?.setAttribute('aria-label', 'Play');
      }
    }

    // ── Shared play/pause logic ──
    async function togglePlayback() {
      if (audio.paused) {
        if (!armLanded) {
          armLanded = true;
          hasStarted = true;
          landArm(async () => {
            try {
              await audio.play();
              setPlaying(true);
            } catch(e) {
              console.error('Playback failed:', e);
            }
          });
        } else {
          try {
            await audio.play();
            setPlaying(true);
          } catch(e) {
            console.error('Playback failed:', e);
          }
        }
      } else {
        audio.pause();
        setPlaying(false);
      }
    }

    // ── Content play button (mobile State 1 → State 2) ──
    contentPlayBtn?.addEventListener('click', () => {
      openSheet();
      // Small delay so the sheet animation starts before arm swings
      setTimeout(() => togglePlayback(), 120);
    });

    // ── Main turntable play button ──
    playBtn?.addEventListener('click', togglePlayback);

    // ── Mini-player play button ──
    miniPlayBtn?.addEventListener('click', togglePlayback);

    // ── Progress updates ──
    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = audio.currentTime / audio.duration;
      if (scrubFill)  scrubFill.style.width = `${pct * 100}%`;
      if (scrubThumb) scrubThumb.style.left  = `${pct * 100}%`;
      scrubTrack?.setAttribute('aria-valuenow', Math.round(pct * 100));
      if (timeElapsed) timeElapsed.textContent = fmtTime(audio.currentTime);
      if (timeTotal)   timeTotal.textContent   = fmtTime(audio.duration);
    });

    audio.addEventListener('ended', () => setPlaying(false));

    // ── Skip ──
    skipBack?.addEventListener('click', () => { audio.currentTime = Math.max(0, audio.currentTime - 15); });
    skipFwd?.addEventListener('click',  () => { audio.currentTime = Math.min(audio.duration || Infinity, audio.currentTime + 15); });

    // ── Speed (cycling) ──
    const speedCycleBtn = document.getElementById('speed-cycle-btn');
    const speeds = [1, 1.25, 1.5];
    let speedIdx = 0;
    speedCycleBtn?.addEventListener('click', () => {
      speedIdx = (speedIdx + 1) % speeds.length;
      audio.playbackRate = speeds[speedIdx];
      speedCycleBtn.textContent = speeds[speedIdx] + '×';
    });

    // ── Mute toggle ──
    const muteBtn = document.getElementById('mute-btn');
    const iconUnmuted = document.getElementById('icon-unmuted');
    const iconMuted   = document.getElementById('icon-muted');
    let isMuted = false;
    muteBtn?.addEventListener('click', () => {
      isMuted = !isMuted;
      audio.muted = isMuted;
      if (iconUnmuted) iconUnmuted.style.display = isMuted ? 'none' : '';
      if (iconMuted)   iconMuted.style.display   = isMuted ? '' : 'none';
      muteBtn?.setAttribute('aria-label', isMuted ? 'Unmute' : 'Mute');
    });

    // ── Scrubber seek (click + drag) ──
    let scrubbing = false;
    function seek(e) {
      if (!audio.duration) return;
      const rect = scrubTrack.getBoundingClientRect();
      const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      audio.currentTime = pct * audio.duration;
    }
    scrubTrack?.addEventListener('mousedown', e => { scrubbing = true; seek(e); });
    document.addEventListener('mousemove', e => { if (scrubbing) seek(e); });
    document.addEventListener('mouseup', () => { scrubbing = false; });
    scrubTrack?.addEventListener('touchstart', e => { scrubbing = true; seek(e.touches[0]); }, { passive: true });
    document.addEventListener('touchmove', e => { if (scrubbing) seek(e.touches[0]); }, { passive: true });
    document.addEventListener('touchend', () => { scrubbing = false; });
  }

  // ── Marquee ──
  function initMarquee() {
    const text      = document.getElementById('sheet-title-text');
    const container = document.getElementById('sheet-title-marquee');
    if (!text || !container) return;
    text.classList.remove('marquee-active');
    const overflow = text.scrollWidth - container.clientWidth;
    if (overflow > 5) {
      text.style.setProperty('--marquee-offset', `-${overflow}px`);
      text.classList.add('marquee-active');
    }
  }
  initMarquee();
  window.addEventListener('resize', initMarquee);

</script>
