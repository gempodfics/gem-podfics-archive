      repeating-linear-gradient(
        177deg,
        transparent        0px,
        transparent        3px,
        rgba(0,0,0,0.13)   3px,
        rgba(0,0,0,0.13)   4px,
        transparent        4px,
        transparent        9px,
        rgba(0,0,0,0.07)   9px,
        rgba(0,0,0,0.07)  10px,
        transparent       10px,
        transparent       15px,
        rgba(220,150,80,0.06) 15px,
        rgba(220,150,80,0.06) 16px,
        transparent       16px,
        transparent       22px
      ),
      linear-gradient(155deg,
        #5e3420 0%, #472512 12%, #3c1e0c 30%,
        #4a2810 55%, #3a1e0c 80%, #2e1608 100%
      );
    box-shadow:
      inset 0 1px 0 rgba(220,160,90,0.18),
      inset 0 -3px 10px rgba(0,0,0,0.35),
      0 0 0 1px rgba(0,0,0,0.55),
      0 4px 0 #130b02,
      0 7px 0 #0c0701,
      0 10px 28px rgba(0,0,0,0.80),
      0 20px 50px rgba(0,0,0,0.45);
  }
  .vinyl-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
  }
  .vinyl-disc {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background:
      repeating-radial-gradient(
        circle at center,
        #0f0f14 0px, #0f0f14 5px,
        #181820 5px, #181820 6px
      );
    box-shadow:
      inset 0 0 30px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.04),
      0 0 0 transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: vinyl-spin 4s linear infinite;
    animation-play-state: paused;
    transition: box-shadow 1.4s ease;
  }
  .vinyl-disc.glowing {
    box-shadow:
      inset 0 0 30px rgba(0,0,0,0.6),
