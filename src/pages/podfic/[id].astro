    width: 2.5rem; height: 4px;
    background: rgba(255,255,255,0.18);
    border-radius: 2px;
  }

  /* ══════════════════════════════════════════════
     LEFT COLUMN: TURNTABLE + CONTROLS
     ══════════════════════════════════════════════ */
  .player-left {
    display: flex;
    flex-direction: column;
    align-items: center;
