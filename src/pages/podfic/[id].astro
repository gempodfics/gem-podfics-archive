---
import Layout from '../../layouts/Layout.astro';
import { getAllPodfics, getPodficById, formatDuration, resolveInternetArchiveAudio } from '../../lib/notion';

export async function getStaticPaths() {
  const all = await getAllPodfics();
  return all.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const p = await getPodficById(id!);

function ratingSlug(r: string) {
  if (r === 'General Audiences') return 'general';
  if (r === 'Teen and Up') return 'teen';
  if (r === 'Mature') return 'mature';
  return 'explicit';
}
function ratingLabel(r: string) {
  if (r === 'General Audiences') return 'General';
  if (r === 'Teen and Up') return 'Teen & Up';
  return r;
}

const coverImg = p.coverArtUrl || p.commissionedArtUrl || '';
const audioSrc = await resolveInternetArchiveAudio(p.internetArchiveUrl);
const hasAudio = !!audioSrc;
const CIRCUMFERENCE = 2 * Math.PI * 94;
---

<Layout title={p.title}>
  <div class="player-page" data-player-state="content" id="player-page">

    <!-- Back button -->
    <button class="back-btn" onclick="history.back()" aria-label="Go back">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
      </svg>
    </button>

    <!-- ══════════════════════════════════════════════
         MOBILE ONLY — State 1: Content page
         ══════════════════════════════════════════════ -->
    <div class="mobile-content" id="mobile-content">

      <!-- Static sleeve + record artwork -->
      <div class="content-artwork">
        <div class="ca-record-peek" aria-hidden="true">
          <div class="ca-record-dot"></div>
        </div>
        <div class="ca-sleeve">
          {coverImg
            ? <img src={coverImg} alt={p.title} class="ca-img" />
            : <div class="ca-placeholder"></div>
          }
          {p.rating && (
            <span class={`rating-badge rating-${ratingSlug(p.rating)}`}>
              {ratingLabel(p.rating)}
            </span>
          )}
        </div>
      </div>

      <!-- Title + meta -->
      <div class="mobile-meta">
        <div class="meta-badges">
          {p.fandoms.map(f => <span class="fandom-pill">{f}</span>)}
          {p.dynamic && <span class="dynamic-pill">{p.dynamic}</span>}
        </div>
        <h1 class="player-title">{p.title}</h1>
        <div class="player-credits">
          {p.artistCredit && (
            <span class="credit-item">Art by <span class="credit-name">{p.artistCredit}</span></span>
          )}
          {p.artistCredit && p.writtenBy && <span class="credit-sep">·</span>}
          {p.writtenBy && (
            <span class="credit-item">
              Written by{' '}
              {p.writtenByUrl
                ? <a href={p.writtenByUrl} target="_blank" rel="noopener" class="credit-link">{p.writtenBy}</a>
                : <span class="credit-name">{p.writtenBy}</span>
              }
            </span>
          )}
        </div>
        {p.multiVoice === 'YES' && p.readWithSegments.length > 0 && (
          <p class="sheet-summary-written">
            Read with{' '}
            {p.readWithSegments.map((seg, i) => (
              <>
                {seg.href
                  ? <a href={seg.href} target="_blank" rel="noopener" class="credit-link">{seg.text}</a>
                  : <span class="credit-name">{seg.text}</span>
                }
                {i < p.readWithSegments.length - 1 ? '' : ''}
              </>
            ))}
          </p>
        )}
        {p.length && (
          <span class="duration-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
            {formatDuration(p.length)}
          </span>
        )}
      </div>

      <!-- Play trigger button -->
      <button class="content-play-btn" id="content-play-btn" aria-label="Play" {!hasAudio && 'disabled'}>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        Play
      </button>

      <!-- Summary -->
      {p.summary && (
        <div class="summary-section">
          <h2 class="summary-heading">Summary</h2>
          <div class="summary-body">
            <p class="summary-text" id="mobile-summary-text">{p.summary}</p>
          </div>
          {p.ao3Url && (
            <a href={p.ao3Url} target="_blank" rel="noopener" class="ao3-link">
              All AO3 Tags
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
            </a>
          )}
        </div>
      )}

    </div><!-- /mobile-content -->

    <!-- ══════════════════════════════════════════════
         PLAYER SHEET
         Mobile: full-screen overlay, slides up on play
         Desktop: transparent left-column wrapper
         ══════════════════════════════════════════════ -->
    <div class="player-sheet" id="player-sheet">

      <!-- Dismiss handle (mobile only) -->
      <button class="sheet-dismiss-btn" id="sheet-dismiss-btn" aria-label="Dismiss player">
        <div class="sheet-handle"></div>
      </button>

      <!-- Sheet title (mobile only) -->
      <div class="sheet-title-row">
        <div class="sheet-title-marquee" id="sheet-title-marquee">
          <span class="sheet-title-text" id="sheet-title-text">{p.title}</span>
        </div>
      </div>

      <!-- ── Left column: turntable + controls ── -->
      <div class="player-left">

        <!-- Turntable assembly -->
        <div class="turntable-assembly">
          <div class="plinth-surface">

            <div class="vinyl-stage">
              <div class="vinyl-disc" id="vinyl-disc">
                <div class="vinyl-label">
                  {coverImg
                    ? <img src={coverImg} alt={p.title} class="label-img" />
                    : <div class="label-placeholder"><svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" opacity="0.3" aria-hidden="true"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg></div>
                  }
                </div>
                <div class="vinyl-sheen" aria-hidden="true"></div>
              </div>

              <svg class="tonearm-svg" id="tonearm-svg" viewBox="0 0 200 200" aria-hidden="true">
                <defs>
                  <linearGradient id="arm-grad" x1="0%" y1="50%" x2="100%" y2="50%">
                    <stop offset="0%"   stop-color="#909090"/>
                    <stop offset="18%"  stop-color="#f4f4ff"/>
                    <stop offset="40%"  stop-color="#808080"/>
                    <stop offset="58%"  stop-color="#383840"/>
                    <stop offset="76%"  stop-color="#787890"/>
                    <stop offset="100%" stop-color="#9898b0"/>
                  </linearGradient>
                  <radialGradient id="cw-grad" cx="33%" cy="28%" r="68%">
                    <stop offset="0%"   stop-color="#d8d8e8"/>
                    <stop offset="45%"  stop-color="#7070a0"/>
                    <stop offset="100%" stop-color="#1c1c2c"/>
                  </radialGradient>
                  <radialGradient id="pivot-outer-grad" cx="30%" cy="25%" r="75%">
                    <stop offset="0%"   stop-color="#5a5a78"/>
                    <stop offset="55%"  stop-color="#222238"/>
                    <stop offset="100%" stop-color="#0c0c1c"/>
                  </radialGradient>
                  <radialGradient id="pivot-grad" cx="35%" cy="30%" r="70%">
                    <stop offset="0%"   stop-color="#e8e8ff"/>
                    <stop offset="40%"  stop-color="#9898b8"/>
                    <stop offset="100%" stop-color="#28283a"/>
                  </radialGradient>
                </defs>

                <g id="tonearm-group" class="tonearm raised">
                  <g transform="translate(26, 10) rotate(-27)">
                    <rect x="-3" y="-18" width="6" height="18" rx="3" fill="url(#arm-grad)"/>
                    <rect x="-10" y="-32" width="20" height="14" rx="3.5" fill="url(#cw-grad)"/>
                    <rect x="-9" y="-31" width="13" height="4" rx="1.5"
                      fill="rgba(255,255,255,0.28)" opacity="0.85"/>
                    <rect x="-3.5" y="0" width="7" height="67" rx="3.5" fill="url(#arm-grad)"/>
                    <rect x="-0.5" y="2" width="3.5" height="63" rx="2" fill="rgba(0,0,0,0.22)"/>
                    <rect x="-3" y="2" width="1.8" height="63" rx="1"
                      fill="rgba(255,255,255,0.40)" opacity="0.7"/>
                    <g id="needle-head-lights">
                      <circle cx="0" cy="67" r="5.5" fill="url(#cw-grad)"/>
                      <circle cx="-2" cy="65" r="1.8" fill="rgba(255,255,255,0.65)"/>
                      <rect x="-7" y="70" width="14" height="14" rx="2.5" fill="url(#cw-grad)"/>
                      <rect x="-6" y="71" width="10" height="4.5" rx="1.5"
                        fill="rgba(255,255,255,0.32)"/>
                      <line x1="0" y1="84" x2="0" y2="88"
                        stroke="#b0b0c8" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="-0.5" y1="84" x2="-0.5" y2="88"
                        stroke="rgba(255,255,255,0.28)" stroke-width="0.5" stroke-linecap="round"/>
                    </g>
                  </g>
                </g>

                <circle cx="26" cy="10" r="13" fill="url(#pivot-outer-grad)"/>
                <circle cx="26" cy="10" r="10" fill="#18182a"/>
                <circle cx="26" cy="10" r="8"  fill="url(#pivot-grad)"/>
                <circle cx="26" cy="10" r="3.5" fill="#14141e"/>
                <circle cx="26" cy="10" r="2"  fill="url(#pivot-grad)"/>
                <circle cx="24" cy="8"  r="1.8" fill="rgba(255,255,255,0.65)" opacity="0.6"/>
                <circle cx="25" cy="7"  r="0.7" fill="rgba(255,255,255,0.92)"/>
              </svg>
            </div>

          </div>
        </div><!-- /turntable-assembly -->

        <!-- Playback controls -->
        <div class="controls">
          <div class="control-row">
            <button class="speed-cycle-btn" id="speed-cycle-btn" aria-label="Playback speed">1×</button>

            <button class="ctrl-btn" id="skip-back" aria-label="Skip back 15 seconds">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
              <span class="ctrl-label">15</span>
            </button>

            <button class="play-btn" id="play-btn" aria-label="Play" {!hasAudio && 'disabled'}>
              <svg id="icon-play" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              <svg id="icon-pause" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
            </button>

            <button class="ctrl-btn" id="skip-fwd" aria-label="Skip forward 15 seconds">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 13c0 3.31-2.69 6-6 6s-6-2.69-6-6 2.69-6 6-6v4l5-5-5-5v4c-4.42 0-8 3.58-8 8s3.58 8 8 8 8-3.58 8-8h-2z"/></svg>
              <span class="ctrl-label">15</span>
            </button>

            <button class="mute-btn" id="mute-btn" aria-label="Mute">
              <svg id="icon-unmuted" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
              <svg id="icon-muted" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
            </button>
          </div>

          <div class="scrubber-row">
            <span class="time-label" id="time-elapsed">0:00</span>
            <div class="scrubber-track" id="scrubber-track" role="slider" aria-label="Audio progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
              <div class="scrubber-fill" id="scrubber-fill"></div>
              <div class="scrubber-thumb" id="scrubber-thumb"></div>
            </div>
            <span class="time-label" id="time-total">{p.length ? formatDuration(p.length) : '--:--'}</span>
          </div>

          {p.summary && (
            <div class="sheet-summary-card">
              <h2 class="sheet-summary-heading">Summary</h2>
              <p class="sheet-summary-meta">
                {[p.fandoms.join(' · '), p.dynamic].filter(Boolean).join(' · ')}
              </p>
              {p.writtenBy && (
                <p class="sheet-summary-written">
                  Written by{' '}
                  {p.writtenByUrl
                    ? <a href={p.writtenByUrl} target="_blank" rel="noopener" class="credit-link">{p.writtenBy}</a>
                    : <span class="credit-name">{p.writtenBy}</span>
                  }
                </p>
              )}
              {p.artistCredit && (
                <p class="sheet-summary-written">Art by <span class="credit-name">{p.artistCredit}</span></p>
              )}
              {p.multiVoice === 'YES' && p.readWithSegments.length > 0 && (
                <p class="sheet-summary-written">
                  Read with{' '}
                  {p.readWithSegments.map((seg, i) => (
                    <>
                      {seg.href
                        ? <a href={seg.href} target="_blank" rel="noopener" class="credit-link">{seg.text}</a>
                        : <span class="credit-name">{seg.text}</span>
                      }
                      {i < p.readWithSegments.length - 1 ? '' : ''}
                    </>
                  ))}
                </p>
              )}
              <div class="sheet-summary-body">
                <p class="summary-text" id="sheet-summary-text">{p.summary}</p>
              </div>
              {p.ao3Url && (
                <a href={p.ao3Url} target="_blank" rel="noopener" class="ao3-link">
                  All AO3 Tags
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                </a>
              )}
            </div>
          )}
        </div>

        {!hasAudio && (
          <p class="no-audio-msg">Audio not yet available for this podfic.</p>
        )}

      </div><!-- /player-left -->

    </div><!-- /player-sheet -->

    <!-- ── Desktop only: Right column metadata card ── -->
    <aside class="player-right">
      <div class="player-meta">
        <div class="meta-badges">
          {p.rating && (
            <span class={`rating-badge rating-${ratingSlug(p.rating)}`}>
              {ratingLabel(p.rating)}
            </span>
          )}
          {p.fandoms.map(f => <span class="fandom-pill">{f}</span>)}
          {p.dynamic && <span class="dynamic-pill">{p.dynamic}</span>}
        </div>
        <h1 class="player-title">{p.title}</h1>
        <div class="player-credits">
          {p.artistCredit && (
            <span class="credit-item">Art by <span class="credit-name">{p.artistCredit}</span></span>
          )}
          {p.artistCredit && p.writtenBy && <span class="credit-sep">·</span>}
          {p.writtenBy && (
            <span class="credit-item">
              Written by{' '}
              {p.writtenByUrl
                ? <a href={p.writtenByUrl} target="_blank" rel="noopener" class="credit-link">{p.writtenBy}</a>
                : <span class="credit-name">{p.writtenBy}</span>
              }
            </span>
          )}
        </div>
        {p.multiVoice === 'YES' && p.readWithSegments.length > 0 && (
          <p class="sheet-summary-written">
            Read with{' '}
            {p.readWithSegments.map((seg, i) => (
              <>
                {seg.href
                  ? <a href={seg.href} target="_blank" rel="noopener" class="credit-link">{seg.text}</a>
                  : <span class="credit-name">{seg.text}</span>
                }
                {i < p.readWithSegments.length - 1 ? '' : ''}
              </>
            ))}
          </p>
        )}
        {p.length && (
          <span class="duration-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
            {formatDuration(p.length)}
          </span>
        )}
      </div>
      {p.summary && (
        <div class="summary-section">
          <h2 class="summary-heading">Summary</h2>
          <div class="summary-body">
            <p class="summary-text" id="summary-text">{p.summary}</p>
          </div>
          {p.ao3Url && (
            <a href={p.ao3Url} target="_blank" rel="noopener" class="ao3-link">
              All AO3 Tags
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
            </a>
          )}
        </div>
      )}
    </aside>

    <!-- ══════════════════════════════════════════════
         MOBILE ONLY — Mini-player bar
         Shown when player is dismissed but audio has started
         ══════════════════════════════════════════════ -->
    <div class="mini-player-bar" id="mini-player-bar" aria-hidden="true">
      <div class="mini-art">
        {coverImg
          ? <img src={coverImg} alt={p.title} class="mini-img" />
          : <div class="mini-placeholder"></div>
        }
      </div>
      <span class="mini-title">{p.title}</span>
      <button class="mini-play-btn" id="mini-play-btn" aria-label="Play">
        <svg id="mini-icon-play" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        <svg id="mini-icon-pause" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>
    </div>

    <!-- Audio element -->
    {hasAudio && (
      <audio id="audio-player" src={audioSrc} preload="none"></audio>
    )}

  </div>
</Layout>

<style>
  /* ══════════════════════════════════════════════
     PAGE SHELL
     ══════════════════════════════════════════════ */
  .player-page {
    position: relative;
    min-height: calc(100vh - 52px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem 4rem;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ══════════════════════════════════════════════
     BACK BUTTON
     ══════════════════════════════════════════════ */
  .back-btn {
    position: absolute;
    top: 0.75rem;
    left: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--bg-surface);
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    z-index: 5;
  }
  .back-btn:hover {
    background: var(--bg-elevated);
    color: var(--text-primary);
  }

  /* ══════════════════════════════════════════════
     MOBILE CONTENT STATE (State 1)
     Hidden on desktop
     ══════════════════════════════════════════════ */
  .mobile-content {
    display: none; /* shown on mobile via media query */
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    padding: 3rem 1.25rem 2rem;
  }

  /* ── Content artwork (static sleeve + record) ── */
  .content-artwork {
    position: relative;
    width: min(280px, 72vw);
    flex-shrink: 0;
  }
  .ca-sleeve {
    position: relative;
    width: 74%;
    aspect-ratio: 1 / 1;
    z-index: 2;
  }
  .ca-img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 8px;
    display: block;
    box-shadow: 0 6px 24px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.07);
  }
  .ca-placeholder {
    width: 100%; height: 100%;
    border-radius: 8px;
    background: radial-gradient(circle, var(--bg-elevated) 0%, var(--bg-surface) 100%);
    box-shadow: 0 6px 24px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.07);
  }
  .ca-record-peek {
    position: absolute;
    top: 0; right: 0;
    width: 74%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    z-index: 1;
    background:
      radial-gradient(ellipse at 32% 28%, rgba(255,255,255,0.07) 0%, transparent 48%),
      repeating-radial-gradient(circle at center, transparent, transparent 7px, rgba(255,255,255,0.04) 7px, rgba(255,255,255,0.04) 8px),
      radial-gradient(circle at center, #2e2e2e 0%, #222 30%, #181818 60%, #0d0d0d 100%);
    box-shadow: 4px 4px 16px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.05);
  }
  .ca-record-dot {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
