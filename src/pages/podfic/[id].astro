  .sheet-summary-body { display: flex; flex-direction: column; gap: 0.5rem; }

  /* ══════════════════════════════════════════════
     MOBILE LAYOUT  (< 768px)
     ══════════════════════════════════════════════ */
  @media (max-width: 767px) {
    /* Reset page shell for mobile */
    .player-page {
      padding: 0;
      max-width: 100%;
      gap: 0;
