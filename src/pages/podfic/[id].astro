    /* Show dismiss button + sheet title row */
    .sheet-dismiss-btn {
      display: flex;
    }
    .sheet-title-row {
      display: flex;
    }

    /* Player-left fills the sheet */
    .player-left {
      padding: 0 1.25rem 2rem;
