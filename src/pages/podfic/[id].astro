  .vinyl-sheen {
    position: absolute; inset: 0; border-radius: 50%;
    pointer-events: none; z-index: 1;
    background:
      radial-gradient(ellipse 58% 38% at 30% 26%, rgba(255,255,255,0.11) 0%, rgba(255,255,255,0.05) 45%, transparent 72%),
      radial-gradient(ellipse 28% 44% at 80% 72%, rgba(255,255,255,0.06) 0%, transparent 62%),
      conic-gradient(from 205deg at 50% 50%,
        transparent 0deg, rgba(190,160,255,0.05) 35deg, rgba(155,205,255,0.04) 75deg,
        transparent 110deg, transparent 200deg, rgba(255,185,220,0.04) 258deg, transparent 300deg);
    mix-blend-mode: screen;
