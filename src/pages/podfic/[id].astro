    /* ── Player sheet: fixed overlay, slides up from bottom ── */
    .player-sheet {
      position: fixed;
      inset: 0;
      top: 52px;
      z-index: 100;
      background: var(--bg-primary);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
