    /* ── Mini-player bar ── */
    .mini-player-bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: 68px;
      background: var(--bg-surface);
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
