---
const navItems = [
  { label: 'Home', href: '/', icon: 'home' },
  { label: 'One Shots', href: '/one-shots', icon: 'one-shot' },
  { label: 'Multi-Chapter', href: '/multi-chapter', icon: 'multi' },
  { label: 'ASMR', href: '/asmr', icon: 'asmr' },
];

const socials = [
  { label: 'Tumblr', href: 'https://www.tumblr.com/blog/gemaesteria', path: 'M14.563 24c-5.093 0-7.031-3.756-7.031-6.411V9.747H5.116V6.648c3.63-1.313 4.512-4.596 4.71-6.469C9.84.051 9.941 0 9.999 0h3.517v6.114h4.801v3.633h-4.82v7.47c.016 1.001.375 2.371 2.207 2.371h.09c.631-.02 1.486-.205 1.936-.419l1.156 3.425c-.436.636-2.4 1.374-4.156 1.404h-.178l.011.002z' },
