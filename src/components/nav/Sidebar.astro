const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- ── Desktop Sidebar ── -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-top">
    <a href="/" class="sidebar-logo" id="sidebar-logo">Gem Podfics</a>
    <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" id="toggle-icon">
        <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    </button>
  </div>

  <nav class="sidebar-nav">
    {navItems.map(item => (
      <a href={item.href} class={`nav-item ${isActive(item.href) ? 'active' : ''}`}>
        <span class="nav-icon">
          {item.icon === 'home' && <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>}
          {item.icon === 'one-shot' && <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg>}
          {item.icon === 'multi' && <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"/></svg>}
          {item.icon === 'asmr' && <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg>}
        </span>
        <span class="nav-label">{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="sidebar-socials">
    {socials.map(s => (
      <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="social-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d={s.path} />
        </svg>
      </a>
    ))}
  </div>
</aside>

<!-- ── Mobile pill nav ── -->
<nav class="mobile-pills" aria-label="Main navigation">
  {navItems.map(item => (
    <a href={item.href} class={`pill ${isActive(item.href) ? 'active' : ''}`}>
      {item.label}
    </a>
  ))}
</nav>

<style>
  /* ── Sidebar ── */
  .sidebar {
    display: none;
  }

  @media (min-width: 768px) {
    .sidebar {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      width: 200px;
      height: 100vh;
      background: var(--bg-surface);
      border-right: 1px solid var(--bg-elevated);
      z-index: 100;
      transition: width 0.25s ease;
      overflow: hidden;
    }

    .sidebar.collapsed {
      width: 64px;
    }
  }

  .sidebar-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1rem 1.5rem 1.25rem;
    min-height: 64px;
    flex-shrink: 0;
  }

  .sidebar-logo {
    color: var(--accent-pink);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    transition: opacity 0.2s ease, width 0.25s ease;
  }

  .sidebar.collapsed .sidebar-logo {
    opacity: 0;
    width: 0;
    pointer-events: none;
  }

  .sidebar-toggle {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .sidebar-toggle:hover { color: var(--text-primary); }

  .sidebar.collapsed .sidebar-toggle #toggle-icon {
    transform: rotate(180deg);
  }

  #toggle-icon {
    transition: transform 0.25s ease;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0 0.75rem;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.5rem;
    border-radius: 6px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    overflow: hidden;
  }

  .nav-item:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
  }

  .nav-item.active {
    color: var(--accent-pink);
    background: var(--bg-elevated);
  }

  .nav-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-label {
    transition: opacity 0.2s ease;
  }

  .sidebar.collapsed .nav-label {
    opacity: 0;
    width: 0;
    overflow: hidden;
  }

  .sidebar-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1.25rem 1rem;
    border-top: 1px solid var(--bg-elevated);
    transition: opacity 0.2s ease;
  }

  .sidebar.collapsed .sidebar-socials {
    opacity: 0;
    pointer-events: none;
  }

  .social-icon {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }

  .social-icon:hover { color: var(--accent-pink); }

  /* ── Mobile pill nav ── */
  .mobile-pills {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg-primary);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--bg-elevated);
  }

  .mobile-pills::-webkit-scrollbar { display: none; }

  @media (min-width: 768px) {
    .mobile-pills { display: none; }
  }

  .pill {
    flex-shrink: 0;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--bg-elevated);
    color: var(--text-secondary);
    transition: background 0.15s, color 0.15s;
  }

  .pill:hover {
    color: var(--text-primary);
  }

  .pill.active {
    background: var(--accent-pink);
    color: #fff;
  }
</style>

<script>
  const sidebar = document.getElementById('sidebar');
  const toggle = document.getElementById('sidebar-toggle');

  // Restore saved state
  if (localStorage.getItem('sidebar-collapsed') === 'true') {
    sidebar?.classList.add('collapsed');
    document.body.classList.add('sidebar-collapsed');
  }

  toggle?.addEventListener('click', () => {
    const isCollapsed = sidebar?.classList.toggle('collapsed');
    document.body.classList.toggle('sidebar-collapsed', isCollapsed);
    localStorage.setItem('sidebar-collapsed', String(isCollapsed));
  });
</script>
