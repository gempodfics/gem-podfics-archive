---
import '../styles/global.css';
import TopBar from '../components/nav/TopBar.astro';
import { Analytics } from '@vercel/analytics/astro';

interface Props {
  title?: string;
  variant?: 'home' | 'collection';
}

const { title = 'Gem Podfics', variant = 'home' } = Astro.props;
const isCollection = variant === 'collection';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The voice of Lost Narratives. A personal podfic archive by Gem Asteria." />
    <title>{title === 'Gem Podfics' ? title : `${title} — Gem Podfics`}</title>
    <link rel="icon" type="image/png" href="/gempodfics-favicon.png" />
  </head>
  <body>
    <TopBar />

    {isCollection ? (
      <>
        <aside class="filter-sidebar" id="filter-sidebar">
          <slot name="sidebar" />
        </aside>
        <div class="filter-backdrop" id="filter-backdrop"></div>
        <main class="collection-content">
          <slot />
        </main>
      </>
    ) : (
      <main class="home-content">
        <slot />
      </main>
    )}
    <Analytics />
  </body>
</html>

<style>
  /* ── Base: clear the fixed top bar ── */
  .home-content,
  .collection-content {
    padding-top: 52px;
    min-height: 100vh;
  }

  /* ── Filter sidebar — mobile: hidden (slides up when open) ── */
  .filter-sidebar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    max-height: 82vh;
    overflow-y: auto;
    background: var(--bg-surface);
    border-top: 2px solid var(--bg-elevated);
    border-radius: 1.25rem 1.25rem 0 0;
    z-index: 200;
    padding: 1.25rem 1.25rem 2.5rem;
    /* start off-screen */
    transform: translateY(100%);
    visibility: hidden;
    transition: transform 0.3s ease, visibility 0.3s ease;
  }

  .filter-sidebar.open {
    transform: translateY(0);
    visibility: visible;
  }

  /* ── Backdrop (mobile only) ── */
  .filter-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 190;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .filter-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Desktop: persistent left sidebar ── */
  @media (min-width: 768px) {
    .filter-sidebar {
      top: 52px;
      bottom: 0;
      left: 0;
      right: auto;
      width: 260px;
      max-height: none;
      border-top: none;
      border-right: 1px solid var(--bg-elevated);
      border-radius: 0;
      padding: 1.75rem 1.25rem 3rem;
      transform: none;
      visibility: visible;
      transition: none;
    }

    .filter-backdrop {
      display: none !important;
    }

    .collection-content {
      margin-left: 260px;
    }
  }
</style>

<script>
  const sidebar = document.getElementById('filter-sidebar');
  const backdrop = document.getElementById('filter-backdrop');
  const openBtn = document.getElementById('filter-open-btn');
  const closeBtn = document.getElementById('filter-close-btn');

  function openFilters() {
    sidebar?.classList.add('open');
    backdrop?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeFilters() {
    sidebar?.classList.remove('open');
    backdrop?.classList.remove('open');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openFilters);
  closeBtn?.addEventListener('click', closeFilters);
  backdrop?.addEventListener('click', closeFilters);
</script>
