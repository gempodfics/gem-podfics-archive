---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Gem Podfics' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The voice of Lost Narratives. A personal podfic archive by Gem Asteria." />
    <title>{title === 'Gem Podfics' ? title : `${title} — Gem Podfics`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
