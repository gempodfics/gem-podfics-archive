---
import '../styles/global.css';
import Sidebar from '../components/nav/Sidebar.astro';

interface Props {
  title?: string;
  fullWidth?: boolean;
}

const { title = 'Gem Podfics', fullWidth = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The voice of Lost Narratives. A personal podfic archive by Gem Asteria." />
    <title>{title === 'Gem Podfics' ? title : `${title} — Gem Podfics`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Sidebar />
    <main class={`page-content${fullWidth ? ' full-width' : ''}`}>
      <slot />
    </main>
  </body>
</html>

<style>
  .page-content {
    padding-top: 52px;
    min-height: 100vh;
  }

  @media (min-width: 768px) {
    .page-content {
      margin-left: 200px;
      padding-top: 0;
      transition: margin-left 0.25s ease;
    }
  }
</style>

<script>
  function applyCollapsedMargin() {
    const content = document.querySelector('.page-content') as HTMLElement | null;
    if (!content) return;
    if (window.innerWidth >= 768 && localStorage.getItem('sidebar-collapsed') === 'true') {
      content.style.marginLeft = '64px';
    } else if (window.innerWidth >= 768) {
      content.style.marginLeft = '200px';
    }
  }

  applyCollapsedMargin();

  document.getElementById('sidebar-toggle')?.addEventListener('click', () => {
    setTimeout(applyCollapsedMargin, 0);
  });
</script>
